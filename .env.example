# ============================================================================
# System Configuration (non-secret)
# Copy to .env and edit as needed.
# For secrets (API keys), copy .env.secrets.example to .env.secrets.
# ============================================================================

# Service
FLASK_PORT=5000
CONTAINER_EXECUTOR_URL=http://localhost:5001
SESSION_IDLE_TIMEOUT=600
LOG_LEVEL=INFO

# Webhook delivery — WazzapAgents' webhook server is always-on (auto-
# restarts on crash), so transient failures are expected to resolve fast.
# These control retry aggressiveness and the pre-flight health check.
# WEBHOOK_RETRY_MAX=10
# WEBHOOK_RETRY_BASE_BACKOFF=0.5
# WEBHOOK_RETRY_MAX_BACKOFF=30.0
# WEBHOOK_HEALTH_CHECK_ATTEMPTS=3
# WEBHOOK_HEALTH_CHECK_TIMEOUT=5.0

# Maximum file size (bytes) to inline as base64 in the webhook callback
# for cross-machine deployments. Files larger than this limit are sent as
# local paths only (works when both services share the same filesystem).
# Default 52428800 (50 MB). Set to 0 to disable base64 inlining.
# SUBAGENT_MAX_INLINE_FILE_BYTES=52428800

# Global concurrency limit for sub-agent sessions. At most this many
# sessions may run their agent loop simultaneously; additional sessions
# wait in a FIFO queue before any LLM call or tool execution.
# Default 1. Set to 0 or negative to clamp to 1.
# SUBAGENT_GLOBAL_LIMIT=1

# LLM (supports OpenAI-compatible endpoints)
LLM_API_KEY=sk-...
# Agent model for routine tasks (default when high_quality=false)
AGENT_MODEL_LOW=gpt-4-turbo
# Agent model for complex tasks requiring deeper reasoning (used when high_quality=true)
# Falls back to AGENT_MODEL_LOW if not set.
AGENT_MODEL_HIGH=o3
# LLM_BASE_URL=  # Optional: custom endpoint (e.g. https://api.openai.com/v1, http://localhost:11434/v1)
AGENT_TEMPERATURE_LOW=0.7
AGENT_TEMPERATURE_HIGH=0.3
